generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    StreamingEvent[]
}

model StreamingEvent {
  id              String   @id @default(cuid())
  recordHash      String   @unique
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ts              DateTime
  platform        String?
  msPlayed        Int
  connCountry     String?
  trackName       String?
  artistName      String?
  albumName       String?
  trackUri        String?
  episodeName     String?
  episodeShowName String?
  episodeUri      String?
  reasonStart     String?
  reasonEnd       String?
  shuffle         Boolean  @default(false)
  skipped         Boolean  @default(false)
  offline         Boolean  @default(false)
  incognitoMode   Boolean  @default(false)
  isrc            String?

  @@index([userId])
  @@index([userId, ts])
  @@index([userId, artistName])
  @@index([userId, trackUri])
  @@index([isrc])
}

model ImageCache {
  cacheKey  String   @id
  imageUrl  String?
  fetchedAt DateTime @default(now())
}

model SpotifyTrackCache {
  spotifyId  String   @id
  trackName  String
  artistName String
  albumName  String?
  isrc       String?
  fetchedAt  DateTime @default(now())

  @@index([isrc])
}
